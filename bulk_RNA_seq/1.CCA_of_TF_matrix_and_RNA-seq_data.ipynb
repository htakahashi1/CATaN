     ]
    }
   ],
   "source": [
　　# ---- Set the following paths to match your environment ----
　　"data_path = "path/to/data\n",    # directory for data                  
   "count_file = "path/to/transcriptome_data\n",   # RNA-seq count file     
   "transcriptome_meta = "path/to/metadata\n",      # sample metadata    
   "color_df = "path/to/color_cord\n",          # color code         
    # -----------------------------------------------------------
    "out_f = paste0(data_path, \"/low_exp_omit_count\")\n",
    "dir.create(out_f)\n",
    "\n",
    "count_df=read.table(count_file, header=1)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "4d228b24",
   "metadata": {},
   "outputs": [],
   "source": [
    "count_df1=count_df %>% separate(Name, c(\"ENSGID\", \"ver\"), sep=\"\\\\.\")\n",
    "rownames(count_df1)=count_df1$ENSGID"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "e681ae5d",
   "metadata": {},
   "outputs": [],
   "source": [
    "count_df2=count_df1[,c(-1, -2, -3)]\n",
    "cpm_tmp    = cpm(count_df2)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "aa1c3115",
   "metadata": {},
   "outputs": [],
   "source": [
    "f1      <- pOverA(p=0.15 , A=10 )\n",
    "ffun    <- filterfun(f1)                        \n",
    "obj     <- genefilter(count_df2, ffun)           \n",
    "count_sub_fil <- rownames(count_df2[obj,]) \n",
    "f2      <- pOverA(p=0.15 , A=1 ) \n",
    "ffun2    <- filterfun(f2)                       \n",
    "obj2    <- genefilter(cpm_tmp, ffun2)      \n",
    "count_sub_fil2 <- rownames(count_df2[obj2,])  \n",
    " \n",
    "count_tmp_3= count_df2[intersect(count_sub_fil,count_sub_fil2),]\n",
    "## Check\n",
    "print(\"## Low Exp Gene filtering ##\")\n",
    "paste0(\"original gene num : \",nrow(count_df2))     %>% print()\n",
    "paste0(\"after filter gene num : \",nrow(count_tmp_3)) %>% print()\n",
    "print(\"## Low Exp Gene filtering ##\")\n",
    "   \n",
    "write.table(data.frame(gene=rownames(count_tmp_3), count_tmp_3), paste0(out_f, \"/low_gene_omitted_count.txt\"),row.names=FALSE,col.names=TRUE, sep=\"\\t\", append=F, quote=F)"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "88cf4eea-de07-4e7a-845f-af4099227ba8",
   "metadata": {},
   "source": [
    "# step2 obtain the intersect genes between TF-GRN matrix and RNA-seq and normalize RNA-seq count data by TMM normalization"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "df3e0d46-56d0-43c6-924e-c7831a4548f3",
   "metadata": {},
   "outputs": [],
   "source": [
    "TF_df=read.table(\"/home/imgtaka/TF_matrix/TF_matrix_tuning/TF_gene_exp_d0_10K/TF_gene_flag_matrix.txt\", header=1,row.names=1)\n",
    "#You can download TF_gene_flag_matrix.txt from data folder."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "d530c5e0-141f-4f24-b14d-41b24463152c",
   "metadata": {},
   "outputs": [],
   "source": [
    "TF_df2=TF_df %>% separate(gene_name, c(\"gene\", \"ver\"), sep=\"\\\\.\") %>% dplyr::select(-c(\"ver\"))\n",
    "unique_df=TF_df2[!(duplicated(TF_df2$gene) | duplicated(TF_df2$gene, fromLast = TRUE)),]\n",
    "rownames(unique_df)=unique_df$gene\n",
    "unique_df2=unique_df %>% dplyr::select(-c(\"gene\"))\n",
    "data_path=<path_to_data>\n",
    "low_exp_omit_path=paste0(out_f, \"/low_gene_omitted_count.txt\")\n",
    "\n",
    "count_df=read.table(low_exp_omit_path, header=1, row.names=1)\n",
    "\n",
    "intersect_genes=intersect(rownames(count_df), rownames(unique_df2))\n",
    "length(intersect_genes)\n",
    "\n",
    "##save Gene-TF binding site association matrix\n",
    "intersect_TF_df=unique_df2[intersect_genes, ]\n",
    "    \n",
    "\n",
    "#out_f_mat=path_to_output_directory_of_TF_matrix_and_transcriptome_matrix\n",
    "  \n",
    "write.table(data.frame(gene=rownames(intersect_TF_df), intersect_TF_df), paste0(data_path, \"/intersect_gene_TF.txt\"),row.names=FALSE,col.names=TRUE, sep=\"\\t\", append=F, quote=F)\n",
    "\n",
    "##save RNA-seq logCPM\n",
    "intersect_GTEx_df=GTExcount_df[intersect_genes, ]\n",
    "### edgeR TMM norm\n",
    "dge2     = DGEList(counts= intersect_GTEx_df, genes=rownames(intersect_GTEx_df))\n",
    "dge_n2   = calcNormFactors( dge2 ,method=\"TMM\")\n",
    "\n",
    "\n",
    "logCPM3  = log2(cpm(dge_n2)+1) %>% as.data.frame()\n",
    "write.table(data.frame(gene=rownames(logCPM3), logCPM3), paste0(data_path, \"/intersect_gene_TMM_logCPM.txt\"),row.names=FALSE,col.names=TRUE, sep=\"\\t\", append=F, quote=F)\n",
    "\n"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "dd80bcd9-91ab-45b7-a805-b0ef01cb1d98",
   "metadata": {},
   "source": [
    "# step3 CCA"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "e63584dc-d1e0-4739-823c-983058b07d63",
   "metadata": {},
   "outputs": [],
   "source": [
    "\n",
    "out_f_result=paste0(data_path,\"/result\")\n",
    "#out_f_result=path_to_output_directory_of_CATaN_output\n",
    "dir.create(out_f, recursive = T)\n",
    "\n",
    "\n",
    "TF_df=read.table(paste0(data_path, \"/intersect_gene_TF.txt\"), header=1,row.names=1)\n",
    "transcriptome_df=read.table(paste0(data_path, \"/intersect_gene_TMM_logCPM.txt\"), header=1, row.names=1)\n",
    "i=10000\n",
    
    "transcriptome_meta[\"id\"] <- lapply(transcriptome_meta[\"SAMPID\"], gsub, pattern=\"-\", replacement = \"\\\\.\")\n",
    "colnames(color_df)=c(\"cluster\", \"color_c\")\n",
    "transcriptome_meta2=transcriptome_meta %>% dplyr::select(c(\"id\", \"SMTS\"))\n",
    "colnames(transcriptome_meta2)=c(\"id\", \"cluster\")\n",
    "\n",
    "merge_df=data.frame(id=colnames(transcriptome_df))\n",
    "merge_df2=left_join(merge_df, transcriptome_meta2, by=\"id\")\n",
    "transcriptome_df_2   = transcriptome_df %>% mutate(var=apply(.,1,var))\n",
    "transcriptome_df_3   = transcriptome_df_2[order(GTEx_df_2$var,decreasing=T),] %>% .[1:as.numeric(i),] %>% dplyr::select(-var)\n",
    "TF_df_2   = TF_df %>% mutate(var=apply(.,1,var))\n",
    "TF_df_3   = TF_df_2[order(TF_df_2$var,decreasing=T),] %>% .[1:as.numeric(i),] %>% dplyr::select(-var)\n",
    "\n",
    "\n",
    "highly_variable_genes=intersect(rownames(TF_df_3), rownames(transcriptome_df_3))\n",
    "gene_num=length(highly_variable_genes)\n",
    "TF_df_highly=TF_df[highly_variable_genes,]\n",
    "transcriptome_df_highly=transcriptome_df[highly_variable_genes,]\n",
    "TF_max=apply(TF_df_highly,2,max)\n",
    "TF_min=apply(TF_df_highly,2,min)\n",
    "TF_min[TF_min==1] 　\n",
    "TF_allzero=TF_max[TF_max==0] \n",
    "TF_allzero_names=names(TF_allzero)\n",
    "TF_df_highly_nonzero=TF_df_highly %>% select(-TF_allzero_names)\n",
    "\n",
    "\n",
    "X <- as.matrix(TF_df_highly_nonzero)\n",
    "Y <- as.matrix(transcriptome_df_highly)\n",
    "\n",
    "\n",
    "\n",
    "scaled_X= apply(X,1,function(x){ (x - mean(x))/sd(x) }) \n",
    "scaled_Y= apply(Y,1,function(x){ (x - mean(x))/sd(x) })\n",
    "scaled_X2= apply(scaled_X,1,function(x){ (x - mean(x))/sd(x) }) \n",
    "scaled_Y2= apply(scaled_Y,1,function(x){ (x - mean(x))/sd(x) })\n",
    "scaled_Y2_t=t(scaled_Y2)\n",
    "scaled_X2_t=t(scaled_X2)\n",
    "NA_colnames <-as.data.frame(scaled_X2_t) %>%\n",
    "  select_if(function(x) any(is.na(x))) %>%\n",
    "  colnames()\n",
    "\n",
    "length(NA_colnames) #zero\n",
    "\n",
    "scaled_X3_t=as.data.frame(scaled_X2_t) %>% dplyr::select(-all_of(NA_colnames)) %>% as.matrix()\n",
    "\n",
    "scaled_Y3=scaled_Y2[colnames(scaled_X3_t),]\n",
    "scaled_Y3_t=t(scaled_Y3)\n",
    "\n",
    "XtY=scaled_X3_t %*% scaled_Y3\n",
    "\n",
    "\n",
    "# SVD\n",
    "\n",
    "svd_res=svd(XtY)\n",
    "\n",
    "\n",
    "\n",
    "\n",
    "\n",
    "u=svd_res$u[,1:10]\n",
    "X_u_df=as.data.frame(u)\n",
    "\n",
    "colnames(X_u_df)=c(\"CC1_rotation\", \"CC2_rotation\", \"CC3_rotation\", \"CC4_rotation\", \"CC5_rotation\", \"CC6_rotation\", \"CC7_rotation\", \"CC8_rotation\", \"CC9_rotation\", \"CC10_rotation\")\n",
    "\n",
    "X_u_df$id=colnames(TF_df_highly_nonzero)\n",
    "\n",
    "X_u_df2=X_u_df\n",
    "\n",
    "v=svd_res$v[,1:10]\n",
    "Y_v_df=as.data.frame(v)\n",
    "\n",
    "colnames(Y_v_df)=c(\"CC1_rotation\", \"CC2_rotation\", \"CC3_rotation\", \"CC4_rotation\", \"CC5_rotation\", \"CC6_rotation\", \"CC7_rotation\", \"CC8_rotation\", \"CC9_rotation\", \"CC10_rotation\")\n",
    "\n",
    "Y_v_df$id=colnames(transcriptome_df_highly)\n",
    "\n",
    "Y_v_df2=left_join(Y_v_df, transcriptome_meta2, by=\"id\")\n",
    "\n",
    "out_f3=paste0(out_f_result,\"/raw_CC\")\n",
    "dir.create(out_f3, recursive = T)\n",
    "\n",
    "                        \n",
    "CC_list=c(\"CC1_rotation\", \"CC2_rotation\", \"CC3_rotation\", \"CC4_rotation\", \"CC5_rotation\", \"CC6_rotation\", \"CC7_rotation\", \"CC8_rotation\", \"CC9_rotation\", \"CC10_rotation\")\n",
    "\n",
    "for (CC in CC_list){\n",
    "    CC_df=X_u_df[,c(\"id\",CC)]\n",
    "    write.table(CC_df, paste0(out_f3, \"/\",  CC, \"_CCscore.txt\"),row.names=FALSE,col.names=FALSE, sep=\"\\t\", append=F, quote=F)\n",
    "}\n",
    "\n",
    "out_f4=paste0(out_f_result,\"/transcriptome_raw_CC\")\n",
    "dir.create(out_f4, recursive = T)\n",
    "\n",
    "                        \n",
    "CC_list=c(\"CC1_rotation\", \"CC2_rotation\", \"CC3_rotation\", \"CC4_rotation\", \"CC5_rotation\", \"CC6_rotation\", \"CC7_rotation\", \"CC8_rotation\", \"CC9_rotation\", \"CC10_rotation\")\n",
    "\n",
    "for (CC in CC_list){\n",
    "    CC_df=Y_v_df[,c(\"id\",CC)]\n",
    "    write.table(CC_df, paste0(out_f4, \"/\",  CC, \"_CCscore.txt\"),row.names=FALSE,col.names=FALSE, sep=\"\\t\", append=F, quote=F)\n",
    "}\n",
    "\n",
    "all_svd_vec=svd_res$d\n",
    "rownames(Y_v_df)=Y_v_df$id\n",
    "Y_v_df_Cor=Y_v_df %>% dplyr::select(-id)\n",
    "print(identical(rownames(scaled_Y3_t), rownames(Y_v_df_Cor))) #TRUE\n",
    "            "
   ]
  },
  {
   "cell_type": "markdown",
   "id": "1bbb5368-c019-4a11-b32e-597f1a49ff10",
   "metadata": {},
   "source": [
    "## output parameters"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "599101c8-37f6-4019-add5-d336b4224d19",
   "metadata": {},
   "outputs": [],
   "source": [
    "#output parameters\n",
    "\n",
    "merge_df=data.frame(matrix(rep(0, 10), ncol=10))[0,]\n",
    "valiance_list=data.frame(matrix(rep(0, 10), ncol=10))\n",
    "colnames(valiance_list)=c(paste0(\"CC\", seq(10)))\n",
    "for (CC_n in seq(10)){\n",
    "    for (i in seq(ncol(scaled_Y3_t))){\n",
    "        valiance_list[1,CC_n]=valiance_list[1,CC_n]+((cor(scaled_Y3_t[,i], Y_v_df_Cor[,CC_n]))**2)\n",
    "    }\n",
    "}\n",
    "val_df=valiance_list/ncol(scaled_Y3_t)\n",
    "rownames(val_df)=c(\"transcriptome_variance_explained_by_CC\")\n",
    "\n",
    "X_u_df_val=X_u_df %>% dplyr::select(-id)\n",
    "valiance_list_x=data.frame(matrix(rep(0, 10), ncol=10))\n",
    "colnames(valiance_list_x)=c(paste0(\"CC\", seq(10)))\n",
    "for (k in seq(10)){\n",
    "    for (i in seq(ncol(scaled_X3_t))){\n",
    "        valiance_list_x[1,k]=valiance_list_x[1,k]+((cor(scaled_X3_t[,i], X_u_df_val[,k]))**2)\n",
    "    }\n",
    "}\n",
    "val_df_x=valiance_list_x/ncol(scaled_X3_t)\n",
    "rownames(val_df_x)=c(\"TF_variance_explained_by_CC\")\n",
    "merge_df=rbind(val_df, val_df_x)\n",
    "\n",
    "all_svd_vec=svd_res$d\n",
    "sv_df=data.frame(matrix(rep(0, 10), ncol=10))\n",
    "colnames(sv_df)=c(paste0(\"CC\", seq(10)))\n",
    "for (i in seq(10)){\n",
    "    sv_df[1,i]=(all_svd_vec[i])/sum(all_svd_vec)\n",
    "}\n",
    "rownames(sv_df)=c(\"sv\")\n",
    "merge_df=rbind(merge_df, sv_df)\n",
    "\n",
    "SCF_df=data.frame(matrix(rep(0, 10), ncol=10))\n",
    "colnames(SCF_df)=c(paste0(\"CC\", seq(10)))\n",
    "for (i in seq(10)){\n",
    "    SCF_df[1,i]=(svd_res$d[i])^2/sum(all_svd_vec^2)\n",
    "}\n",
    "rownames(SCF_df)=c(\"SCF\")\n",
    "merge_df=rbind(merge_df, SCF_df)\n",
    "\n",
    "rownames(X_u_df)=X_u_df$id\n",
    "X_u_df_Cor=X_u_df %>% select(-c(\"id\")) %>% t() %>% as.matrix()\n",
    "scaled_X4=scaled_X3_t %>% as.matrix()\n",
    "a=X_u_df_Cor　%*% scaled_X4\n",
    "Y_v_df_Cormat=Y_v_df %>% select(-c(\"id\")) %>% as.matrix()\n",
    "b=scaled_Y3 %*% Y_v_df_Cormat\n",
    "cor_df=data.frame(matrix(rep(0, 10), ncol=10))\n",
    "colnames(cor_df)=c(paste0(\"CC\", seq(10)))\n",
    "for (i in seq(10)){\n",
    "    cor_df[1,i]=cor(a[i,], b[,i])\n",
    "}\n",
    "rownames(cor_df)=c(\"canonical_correlation\")\n",
    "para_df=rbind(merge_df, cor_df)\n",
    "\n",
    "\n",
    "\n",
    "write.table(data.frame(parameter_name=rownames(para_df), para_df), paste0(out_f_result, \"/CCA_parameter.txt\"),row.names=FALSE,col.names=TRUE, sep=\"\\t\", append=F, quote=F)"
   ]
  },
