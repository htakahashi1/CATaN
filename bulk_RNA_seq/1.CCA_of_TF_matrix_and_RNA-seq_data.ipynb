   "source": [
    "Y_v_df_scale3=Y_v_df2 %>% mutate(cluster2=ifelse(cluster==\"Blood\", \"Blood\", ifelse(cluster==\"Spleen\", \"Spleen\", ifelse(cluster==\"Brain\", \"Brain\", ifelse(cluster==\"Pituitary\", \"Pituitary\", \"Others\")))))\n",
