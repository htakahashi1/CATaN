   "source": [
    "# step1 omit the low expression genes from RNA-seq count data\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 2,
   "id": "d97d4c56",
   "metadata": {
    "scrolled": true
   },
   "outputs": [],
   "source": [
    "library(ggplot2) \n",
    "\n",
    "set.seed(1)\n",
    "library(fs)\n",
    "\n",
    "library(data.table) \n",
    "library(dplyr)\n",
    "library(tidyverse)\n",
    "library(gridExtra)\n",
    "library(data.table) ; library(ggplot2) ; library(reshape2)\n",
    "library(genefilter) ; library(edgeR) ; library(dplyr)\n",
    "library(ggdendro); library(grid)\n",
    "set.seed(1)\n",
    "library(sva)\n",
    "library(fs)\n",
    "library(tidyverse)\n",
    "library(AnnotationDbi)\n",
    "library(org.Hs.eg.db)\n",
    "options(stringsAsFactors=F)\n",
    "options(scipen=100)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 6,
   "id": "139f7a4a",
   "metadata": {},
   "outputs": [
    {
     "name": "stderr",
     "output_type": "stream",
     "text": [
      "Warning message in dir.create(out_f):\n",
